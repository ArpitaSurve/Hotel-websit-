<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aurora Northern Lights Hotel - Luxury Dark Theme</title>
    <style>
        /* FULL BLACK/DARK THEME - COMPLETE WEBSITE */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            background: #000000 !important;
            color: #ffffff;
            min-height: 100vh;
            overflow-x: hidden;
            font-family: 'Arial', sans-serif;
            line-height: 1.6;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 80%, rgba(120,119,198,0.3) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(120,119,198,0.3) 0%, transparent 50%),
                radial-gradient(circle at 40% 40%, rgba(120,119,198,0.2) 0%, transparent 50%);
            z-index: -1;
            animation: auroraFloat 20s ease-in-out infinite;
        }

        @keyframes auroraFloat {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(30px, -30px) rotate(120deg); }
            66% { transform: translate(-20px, 20px) rotate(240deg); }
        }

        /* SINGLE STICKY NAV - FIXED */
        nav {
            position: sticky;
            top: 0;
            background: rgba(10, 10, 20, 0.98);
            padding: 1rem 2rem;
            border-radius: 0 0 25px 25px;
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(0, 212, 255, 0.3);
            z-index: 1000;
            text-align: center;
        }

        nav a {
            color: #00d4ff;
            text-decoration: none;
            margin: 0 2rem;
            font-weight: bold;
            position: relative;
            font-size: 1.1rem;
            transition: all 0.3s ease;
        }

        nav a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 3px;
            background: linear-gradient(90deg, #00d4ff, #ff6b9d);
            transition: width 0.3s ease;
        }

        nav a:hover::after, nav a.active::after {
            width: 100%;
        }

        nav a:hover {
            color: #ff6b9d;
            text-shadow: 0 0 20px rgba(255, 107, 157, 0.5);
        }

        /* HEADER WITH WORKING SLIDESHOW */
        header {
            min-height: 100vh;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 120px 2rem 4rem;
            background: linear-gradient(135deg, #0a0a1f 0%, #000428 50%, #004e92 100%);
        }

        header h1 {
            font-size: 3.5rem;
            margin-bottom: 2rem;
            background: linear-gradient(135deg, #00d4ff, #ff6b9d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 30px rgba(0, 212, 255, 0.5);
        }

        header p {
            font-size: 1.6rem;
            margin-bottom: 3rem;
            max-width: 600px;
        }

        /* PERFECT WORKING SLIDESHOW */
        #hero-slideshow {
            width: 90%;
            max-width: 1000px;
            height: 450px;
            position: relative;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 30px 80px rgba(0,0,0,0.8);
            border: 2px solid rgba(0, 212, 255, 0.3);
        }

        .hero-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            transition: opacity 1s ease-in-out;
        }

        .hero-slide.active {
            opacity: 1;
        }

        /* SECTIONS */
        section {
            background: rgba(10, 10, 20, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(100, 150, 255, 0.3);
            margin: 5rem auto;
            padding: 4rem 3rem;
            border-radius: 25px;
            max-width: 1200px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.7);
            position: relative;
            overflow: hidden;
        }

        h2 {
            background: linear-gradient(135deg, #00d4ff, #ff6b9d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 2rem;
            font-size: 2.8rem;
        }

        /* FORMS */
        button, input[type="submit"], select, input {
            background: linear-gradient(145deg, #1a1a2e, #16213e);
            border: 2px solid #00d4ff;
            color: #ffffff;
            padding: 15px 25px;
            border-radius: 50px;
            font-size: 1rem;
            transition: all 0.3s ease;
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
            margin: 0.5rem;
        }

        button:hover, input[type="submit"]:hover, select:hover {
            box-shadow: 0 0 40px rgba(0, 212, 255, 0.7);
            transform: translateY(-3px);
            border-color: #ff6b9d;
        }

        /* GALLERY */
        #gallery div {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        #gallery img {
            width: 100%;
            height: 250px;
            object-fit: cover;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
            transition: all 0.4s ease;
            cursor: pointer;
        }

        #gallery img:hover {
            transform: scale(1.05) rotate(1deg);
            box-shadow: 0 30px 60px rgba(0, 212, 255, 0.4);
        }

        /* NOTIFICATIONS */
        .notification {
            position: fixed;
            top: 100px;
            right: -400px;
            padding: 1.5rem 2.5rem;
            border-radius: 15px;
            color: white;
            font-weight: bold;
            z-index: 10000;
            transition: all 0.4s ease;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        }

        .notification.success { background: linear-gradient(135deg, #00d4ff, #0099cc); }
        .notification.error { background: linear-gradient(135deg, #ff4757, #ff3838); }
        .notification.info { background: linear-gradient(135deg, #ffa726, #fb8c00); }

        /* LIGHTBOX */
        .lightbox {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.95);
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .lightbox-content {
            background: rgba(20, 20, 40, 0.95);
            padding: 3rem;
            border-radius: 25px;
            text-align: center;
            max-width: 90%;
            max-height: 90%;
            position: relative;
        }

        .close-lightbox {
            position: absolute;
            top: 20px;
            right: 30px;
            font-size: 2rem;
            color: #00d4ff;
            cursor: pointer;
        }

        @media (max-width: 768px) {
            nav a { margin: 0 1rem; font-size: 1rem; }
            header h1 { font-size: 2.5rem; }
            section { margin: 2rem 1rem; padding: 2rem; }
        }
    </style>
</head>
<body>
    <!-- SINGLE NAVIGATION -->
    <nav>
        <a href="#home" class="active">🏠 Home</a>
        <a href="#gallery">🖼️ Gallery</a>
        <a href="#rooms">🛏️ Rooms</a>
        <a href="#contact">📧 Contact</a>
    </nav>

    <!-- HEADER WITH WORKING SLIDESHOW -->
    <header id="home">
        <h1>🌌 Aurora Northern Lights Hotel</h1>
        <p>Experience luxury under the dancing lights of the Arctic sky</p>
        <div id="hero-slideshow">
            <img class="hero-slide active" src="pic3.webp" alt="Aurora Borealis">
            <img class="hero-slide" src="pic2.jpg" alt="Glass Igloo">
            <img class="hero-slide" src="pic1.jpeg" alt="Snowy Cabin">
        </div>
    </header>

    <!-- GALLERY SECTION -->
    <section id="gallery">
        <h2>🏔️ Photo Gallery</h2>
        <div>
            <img src="https://assets.architecturaldigest.in/photos/67daf3d5991d04175a2d17e3/master/w_1600,c_limit/northern-lights-06.jpg" alt="Aurora over mountains">
            <img src="https://www.narcity.com/media-library/image.jpg?id=25915720&width=1245&height=700&coordinates=0%2C0%2C0%2C0" alt="Glass Igloo Suite">
            <img src="https://www.meganstarr.com/wp-content/uploads/2024/11/NLV-Saariselka-6-second-exposure-e1730535318699.jpg" alt="Northern Lodge">
            <img src="https://assets.architecturaldigest.in/photos/67daf3ce991d04175a2d17e1/master/w_1600,c_limit/GettyImages-1165910675.jpg" alt="Winter landscape">
            <img src="pic3.webp">
            <img src="pic2.jpg">
        </div>
    </section>

    <!-- ROOMS SECTION -->
    <section id="rooms">
        <h2>🛏️ Room Pricing Calculator</h2>
        <p>Select your perfect room and calculate your stay:</p>
        <select id="roomtype">
            <option value="Glass Igloo Suite">Glass Igloo Suite - €250/night</option>
            <option value="Aurora Cabin">Aurora Cabin - €180/night</option>
            <option value="Northern Lodge Room">Northern Lodge Room - €120/night</option>
        </select>
        <button onclick="calculatePrice()">Calculate Price ✨</button>
        <p id="price-result" style="margin-top: 1rem; font-size: 1.3rem; color: #00d4ff;"></p>
    </section>

    <!-- CONTACT SECTION -->
    <section id="contact">
        <h2>📧 Book Your Stay</h2>
        <form id="contact-form">
            <input type="text" name="name" placeholder="Your Name *" required>
            <input type="email" name="email" placeholder="Your Email *" required>
            <input type="date" name="checkin" required>
            <button type="submit">Check Availability</button>
        </form>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Smooth scrolling
            document.querySelectorAll('nav a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    e.preventDefault();
                    document.querySelector(this.getAttribute('href')).scrollIntoView({
                        behavior: 'smooth', block: 'start'
                    });
                });
            });

            // All features
            createAuroraEffect();
            setupContactForm();
            setupGallery();
            setupActiveNav();
            setupRoomCalculator();
            setupScrollAnimations();
            setupSlideshow();
            setupParticleEffect();
        });

        // PERFECT SLIDESHOW - 100% WORKING
        function setupSlideshow() {
            const slides = document.querySelectorAll('.hero-slide');
            let current = 0;
            setInterval(() => {
                slides[current].classList.remove('active');
                current = (current + 1) % slides.length;
                slides[current].classList.add('active');
            }, 3500);
        }

        // Aurora effect
        function createAuroraEffect() {
            const header = document.querySelector('header');
            let time = 0;
            setInterval(() => {
                time += 0.02;
                const colors = [
                    `hsl(${200 + Math.sin(time) * 30}, 70%, 40%)`,
                    `hsl(${220 + Math.sin(time + 1) * 30}, 80%, 35%)`,
                    `hsl(${240 + Math.sin(time + 2) * 30}, 90%, 30%)`
                ];
                header.style.boxShadow = `0 0 50px ${colors[0]}, 0 0 100px ${colors[1]}, inset 0 0 50px ${colors[2]}`;
            }, 100);
        }

        // Contact form
        function setupContactForm() {
            document.querySelector('#contact-form').addEventListener('submit', function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                const name = formData.get('name');
                showNotification(`Checking availability for ${name}...`, 'info');
                setTimeout(() => {
                    showNotification('✅ Rooms available! We\'ll email you shortly.', 'success');
                    this.reset();
                }, 2000);
            });
        }

        // Notification
        function showNotification(message, type = 'info') {
            const existing = document.querySelector('.notification');
            if (existing) existing.remove();
            const notification = document.createElement('div');
            notification.className = `notification ${type}`;
            notification.textContent = message;
            document.body.appendChild(notification);
            requestAnimationFrame(() => notification.style.right = '20px');
            setTimeout(() => {
                notification.style.right = '-400px';
                setTimeout(() => notification.remove(), 400);
            }, 4000);
        }

        // Gallery lightbox
        function setupGallery() {
            document.querySelectorAll('#gallery img').forEach(img => {
                img.addEventListener('click', function() {
                    const lightbox = document.createElement('div');
                    lightbox.className = 'lightbox';
                    lightbox.innerHTML = `
                        <div class="lightbox-content">
                            <span class="close-lightbox">&times;</span>
                            <img src="${this.src}" alt="${this.alt}">
                            <p>${this.alt}</p>
                        </div>
                    `;
                    document.body.appendChild(lightbox);
                    lightbox.querySelector('.close-lightbox').onclick = () => lightbox.remove();
                    lightbox.onclick = e => e.target === lightbox && lightbox.remove();
                });
            });
        }

        // Active nav
        function setupActiveNav() {
            window.addEventListener('scroll', () => {
                const sections = document.querySelectorAll('section[id], header[id]');
                let current = 'home';
                sections.forEach(section => {
                    if (window.scrollY >= (section.offsetTop - 200)) {
                        current = section.getAttribute('id');
                    }
                });
                document.querySelectorAll('nav a').forEach(a => {
                    a.classList.toggle('active', a.getAttribute('href') === `#${current}`);
                });
            });
        }

        // Room calculator
        function setupRoomCalculator() {
            const rooms = {'Glass Igloo Suite': 250, 'Aurora Cabin': 180, 'Northern Lodge Room': 120};
            window.calculatePrice = () => {
                const roomSelect = document.querySelector('#roomtype');
                const price = rooms[roomSelect.value];
                const nights = prompt('How many nights?', '1');
                if (nights && !isNaN(nights)) {
                    const total = (price * parseInt(nights)).toLocaleString();
                    document.getElementById('price-result').textContent = `Total: €${total} for ${nights} nights ✨`;
                    showNotification(`Total: €${total} for ${nights} nights`, 'success');
                }
            };
        }

        // Scroll animations
        function setupScrollAnimations() {
            const observer = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, { threshold: 0.1 });
            document.querySelectorAll('section, header').forEach(section => {
                section.style.opacity = '0';
                section.style.transform = 'translateY(50px)';
                section.style.transition = 'all 0.8s ease';
                observer.observe(section);
            });
        }

        // Particles
        function setupParticleEffect() {
            const canvas = document.createElement('canvas');
            canvas.style.cssText = 'position:fixed;top:0;left:0;pointer-events:none;z-index:1';
            document.body.appendChild(canvas);
            const ctx = canvas.getContext('2d');
            let particles = [];
            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resize);
            resize();
            for (let i = 0; i < 60; i++) {
                particles.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    vx: (Math.random() - 0.5) * 0.3,
                    vy: Math.random() * 0.3 + 0.1,
                    size: Math.random() * 3 + 1,
                    alpha: Math.random() * 0.5 + 0.2
                });
            }
            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                particles.forEach(p => {
                    ctx.save();
                    ctx.globalAlpha = p.alpha;
                    ctx.fillStyle = '#00d4ff';
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                    ctx.fill();
                    p.x += p.vx;
                    p.y += p.vy;
                    if (p.y > canvas.height) p.y = 0;
                    if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
                    ctx.restore();
                });
                requestAnimationFrame(animate);
            }
            animate();
        }
    </script>
</body>
</html>
